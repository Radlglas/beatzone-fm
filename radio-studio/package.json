{
  "name": "radioflare",
  "version": "1.0.0",
  "description": "RadioFlare — Professional DJ & Radio Playout Software",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build": "electron-builder",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "music-metadata": "^10.0.0",
    "lamejs": "^1.2.1"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.radioflare",
    "productName": "RadioFlare",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,test,__tests__,*.md}",
      "!node_modules/.cache",
      "!**/*.map"
    ],
    "win": {
      "target": [
        { "target": "zip",      "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "RadioFlare-Portable-${version}.exe"
    }
  }
}
